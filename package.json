{
  "name": "job-hunter",
  "private": true,
  "packageManager": "npm@10.9.7",
  "scripts": {
    "dev": "turbo run dev --concurrency=3",
    "build": "turbo build",
    "lint": "turbo lint",
    "dev:web": "turbo dev --filter=web",
    "dev:api": "turbo dev --filter=api"
  },
  "devDependencies": {
    "turbo": "latest"
  },
  "workspaces": ["apps/*", "packages/*"]
}