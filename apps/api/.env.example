# --- Required ---
DATABASE_URL=postgresql://user:password@host:5432/dbname
GEMINI_API_KEY=
JWT_SECRET=                      # 64-char random string: openssl rand -hex 32
GOOGLE_CLIENT_ID=                # from Google Cloud Console → APIs & Services → Credentials
GOOGLE_CLIENT_SECRET=            # from Google Cloud Console → APIs & Services → Credentials
RESEND_API_KEY=                  # from resend.com dashboard

# --- Optional ---
GROQ_API_KEY=                    # fallback when Gemini rate-limits; free at console.groq.com
ALLOWED_ORIGINS=http://localhost:3000   # comma-separated list of allowed CORS origins
FRONTEND_URL=http://localhost:3000     # used for OAuth redirect and email verification links
DEMO_MODE=false                  # set to true to enable the one-click demo path
