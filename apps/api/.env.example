# --- Required ---
DATABASE_URL=postgresql://user:password@host:5432/dbname
GEMINI_API_KEY=

# --- Optional ---
GROQ_API_KEY=                    # fallback when Gemini rate-limits; free at console.groq.com
API_SECRET_KEY=                  # if set, all requests must carry: Authorization: Bearer <value>
ALLOWED_ORIGINS=http://localhost:3000   # comma-separated list of allowed CORS origins
